#!/usr/bin/env zsh

# ==============================================================================
# Anki Audio Normalizer
#
# Description:
# This script normalizes the volume of MP3 audio files in a specified Anki
# collection media folder. It uses ffmpeg's 'loudnorm' filter for intelligent
# volume normalization. The user can choose to process files from the last day,
# week, month, year, or all files.
#
# Dependencies:
# - zsh: The script is written for Zsh.
# - ffmpeg: Must be installed and available in the system's PATH.
#
# Usage:
# 1. Make the script executable: chmod +x normalize_anki_audio.sh
# 2. Run the script: ./normalize_anki_audio.sh
# ==============================================================================

# --- Configuration ---
# Set the path to your Anki collection media folder.
# The default path for Linux is used here. Please adjust if yours is different.
# On macOS, it's typically: "$HOME/Library/Application Support/Anki2/YOUR_PROFILE_NAME/collection.media"
# On Windows, it's typically: "$APPDATA/Anki2/YOUR_PROFILE_NAME/collection.media"
ANKI_MEDIA_DIR="$HOME/.local/share/Anki2/qiyichen/collection.media"

# --- Pre-flight Checks ---

# Check if the Anki media directory exists
if [[ ! -d "$ANKI_MEDIA_DIR" ]]; then
  echo "Error: Anki media directory not found at:"
  echo "$ANKI_MEDIA_DIR"
  echo "Please update the ANKI_MEDIA_DIR variable in the script."
  exit 1
fi

# Check if ffmpeg is installed
if ! command -v ffmpeg &> /dev/null; then
  echo "Error: ffmpeg is not installed."
  echo "Please install ffmpeg to use this script (e.g., 'sudo apt install ffmpeg' or 'brew install ffmpeg')."
  exit 1
fi

# --- User Interaction ---

echo "Anki Audio Normalizer"
echo "---------------------"
echo "This script will normalize MP3 audio files in:"
echo "$ANKI_MEDIA_DIR"
echo
echo "Select a time range to process files from:"
echo "  1) Past 24 Hours (modified in the last day)"
echo "  2) Past Week (modified in the last 7 days)"
echo "  3) Past Month (modified in the last 30 days)"
echo "  4) Past Year (modified in the last 365 days)"
echo "  5) All Time (process all audio files)"
echo

# Prompt the user for their choice
# `read -r "choice?prompt"` is a zsh-specific way to prompt
read -r "choice?Enter your choice [1-5]: "

# --- Main Logic ---

# Set find command arguments based on user's choice.
# We declare find_time_arg as an array to correctly pass arguments to find.
local -a find_time_arg
case $choice in
  1)
    find_time_arg=(-mtime -1)
    echo "\nSearching for MP3 files modified in the past 24 hours..."
    ;;
  2)
    find_time_arg=(-mtime -7)
    echo "\nSearching for MP3 files modified in the past week..."
    ;;
  3)
    find_time_arg=(-mtime -30)
    echo "\nSearching for MP3 files modified in the past month..."
    ;;
  4)
    find_time_arg=(-mtime -365)
    echo "\nSearching for MP3 files modified in the past year..."
    ;;
  5)
    find_time_arg=() # Empty array for no time limit
    echo "\nSearching for all MP3 files..."
    ;;
  *)
    echo "\nInvalid choice. Exiting."
    exit 1
    ;;
esac

# Navigate to the media directory to simplify paths
cd "$ANKI_MEDIA_DIR" || exit

# Find and process the audio files
# We use `find ... -print0` and `while read -d ''` to safely handle filenames
# that might contain spaces or special characters.
# The $find_time_arg array expands to separate arguments.
find . -type f -iname "*.mp3" $find_time_arg -print0 | while read -d '' -r file; do
  
  echo "-> Processing: $file"
  
  # Create a temporary output file with the same extension as the original
  # so that ffmpeg can automatically infer the output format.
  local filename_no_ext="${file%.*}"
  local extension="${file##*.}"
  temp_file=$(mktemp "${filename_no_ext}-norm.XXXXXX.${extension}")

  # Run ffmpeg with the loudnorm filter.
  # -y: Overwrite output files without asking.
  # -i: Input file.
  # -af loudnorm: Apply the dynamic audio normalization filter.
  # -loglevel error: Only show output if an error occurs, keeping the console clean.
  if ffmpeg -y -i "$file" -af loudnorm "$temp_file" -loglevel error; then
    # If ffmpeg command was successful, replace the original file with the normalized one.
    mv "$temp_file" "$file"
    echo "   Normalized successfully."
  else
    # If ffmpeg failed, print an error and remove the temporary file.
    echo "   ERROR: ffmpeg failed to process this file. It has been skipped."
    rm -f "$temp_file"
  fi
done

echo "\nNormalization process complete."
echo "---------------------------"


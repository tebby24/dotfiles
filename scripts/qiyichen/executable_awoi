#!/bin/bash
set -euo pipefail
set -x  # trace every command

source "$HOME/.config/zsh/path"

LOG=/tmp/awoi.log
exec >>"$LOG" 2>&1

echo "---- $(date) ----"
echo "PATH=$PATH"
echo "DISPLAY=${DISPLAY:-<unset>}"

WORD=$(selection-else-clipboard)

echo "WORD='$WORD'"

chinese-tools wordbank add-word "$WORD"

notify-send -t 4000 "word added: $WORD"
